# Copy to .env and fill in (or set as GitHub Actions repo secrets for the scheduled run).
# Only needed if you use --send-email / --send-sms.

# --- Email (any standard SMTP provider: Gmail app password, SendGrid, Mailgun, etc.) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-account@gmail.com
NEWSLETTER_EMAILS=friend1@example.com,friend2@example.com

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15555550100
NEWSLETTER_PHONES=+15555550101,+15555550102

# --- Commissioner's Notes reminder (only needed for the Monday-night reminder email) ---
COMMISSIONER_EMAIL=commissioner@example.com
